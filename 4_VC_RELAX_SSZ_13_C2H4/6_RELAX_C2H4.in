&CONTROL  
outdir='./outdir'
calculation='relax'
pseudo_dir='./'
forc_conv_thr =  0.001
etot_conv_thr = 0.0001
/

&SYSTEM
ibrav       = 0    
ecutwfc     = 60
ecutrho     = 240
nat         = 6
ntyp        = 2
occupations = 'smearing'
smearing    = 'gaussian'
degauss     = 0.02
vdw_corr    = 'dft-d3'
/

&ELECTRONS
conv_thr    =  1.00000e-08
/

&IONS
ion_dynamics = 'bfgs'
/

K_POINTS {gamma}

ATOMIC_SPECIES
H       1.00794  H.upf
C      12.01070  C.upf

